diff --git a/templates/pages/alumni.html b/templates/pages/alumni.html
index 50dd896..b30a257 100644
--- a/templates/pages/alumni.html
+++ b/templates/pages/alumni.html
@@ -210,6 +210,35 @@
     font-weight: 800;
     cursor: pointer;
 }
+
+/* ─── RESPONSIVE OVERRIDES ─── */
+@media (max-width: 1024px) {
+    .hero-headline, .combined-alumni-heading { font-size: 3.8rem; }
+    .get-involved-blue h2 { font-size: 3.2rem; }
+    .form-layout { grid-template-columns: 1fr; gap: 40px; }
+    .form-left h2 { font-size: 2.6rem; }
+}
+
+@media (max-width: 768px) {
+    .alumni-hero { height: 70vh; }
+    .hero-headline, .combined-alumni-heading { font-size: 2.6rem; letter-spacing: -1px; }
+    .once-aiesecer, .alumni-contact-form { padding: 60px 6%; }
+    .get-involved-blue h2 { font-size: 2.2rem; }
+    .slide-unit { padding: 24px; }
+    .slide-unit h3 { font-size: 1.8rem; }
+    .slide-unit p { font-size: 1rem; }
+    .nav-arrow { width: 40px; height: 40px; font-size: 1.1rem; }
+    .prev-btn { left: 8px; }
+    .next-btn { right: 8px; }
+    .form-left h2 { font-size: 2rem; }
+}
+
+@media (max-width: 480px) {
+    .hero-headline, .combined-alumni-heading { font-size: 2rem; }
+    .alumni-sub-description { font-size: 1rem; }
+    .get-involved-blue h2 { font-size: 1.7rem; }
+    .send-pill-btn { align-self: stretch; text-align: center; }
+}
 </style>
 
 <!-- HERO -->
diff --git a/templates/pages/home.html b/templates/pages/home.html
index 4c30fcb..93c9eca 100644
--- a/templates/pages/home.html
+++ b/templates/pages/home.html
@@ -260,6 +260,35 @@
     position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
     background: rgba(0,0,0,0.15); color: white; font-size: 40px;
 }
+
+/* ─── RESPONSIVE OVERRIDES ─── */
+@media (max-width: 1024px) {
+    .social-grid { grid-template-columns: repeat(3, 1fr); }
+    .arch-card { height: 480px; }
+}
+
+@media (max-width: 768px) {
+    .hero-static-text { font-size: 42px; }
+    .hero-moving-text { font-size: 32px; }
+    .arch-grid { gap: 15px; }
+    .arch-card { height: 380px; min-width: 100%; }
+    .partners-banner { flex-direction: column; gap: 25px; text-align: center; padding: 50px 8%; }
+    .partners-banner h2 { font-size: 28px; }
+    .t-grid { flex-wrap: nowrap; overflow-x: hidden; }
+    .t-card { width: 240px; flex: 0 0 240px; padding: 30px 18px; }
+    .t-nav { display: none; }
+    .social-grid { grid-template-columns: repeat(2, 1fr); gap: 6px; }
+}
+
+@media (max-width: 480px) {
+    .hero-static-text { font-size: 32px; }
+    .hero-moving-text { font-size: 22px; }
+    .experience-section { padding: 50px 5%; }
+    .arch-card { height: 300px; }
+    .testimonial-section { padding: 60px 5%; }
+    .t-card { width: 200px; flex: 0 0 200px; }
+    .social-section { padding: 50px 5%; }
+}
 </style>
 
